trait Memory32: Memory {
  type usize = u32;
  type size = u32;

  #[inline]
  fn grow(self, delta: u32) -> u32 {
    wasm::memory_grow(self, delta)
  }

  #[inline]
  fn size(self) -> u32 {
    wasm::memory_size(self)
  }
}

trait Memory64: Memory {
  type usize = u64;
  type size = u64;

  #[inline]
  fn grow(self, delta: Self::usize) -> Self::usize {
    wasm::memory32_grow(self, delta)
  }

  #[inline]
  fn size(self) -> Self::usize {
    wasm::memory32_size(self)
  }
}

