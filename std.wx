const ASCII_CASE_MASK: u8 = 0b0010_0000;
const PAGE_SIZE: u32 = 65536;

pub trait Sized {
  const SIZE: u32;
  const ALIGN: u32;
}

module wasm {
  #[intrinsic]
  pub fn memory_grow<M: Memory>(mem: M, delta: M::usize) -> M::usize;
  #[intrinsic]
  pub memory_size<M: Memory>(mem: M) -> M::usize;

  #[intrinsic]
  pub fn i32_load<M: Memory>(offset: *(M'a)i32) -> i32; 
  #[intrinsic]
  pub i32_load8_u<M: Memory>(offset: M::*i32) -> u8;
  #[intrinsic]
  pub i32_load8_s<M: Memory>(offset: *memory(M) i32) -> i8;
  #[intrinsic]
  pub i32_load16_u<M: Memory>(offset: *memory(M) i32) -> u16;
  #[intrinsic]
  pub i32_load16_s<M: Memory>(offset: *memory(M) i32) -> i16;
  #[intrinsic]
  pub i32_store8<M: Memory>(offset: *memory(M) mut i32, value: u8);

  #[intrinsic]
  pub i32_store<M: Memory>(offset: *memory(M) mut i32, value: i32);
}

fn strlen<M: Memory>(str: M::[]u8) -> M::usize {
  let mut len = 0;
  while unsafe { wasm::i32_load8_u(str.bytes + len) } != 0 {
    len += 1;
  }
  len
}

