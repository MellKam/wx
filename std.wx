trait Add {
  fn add(self, other: Self) -> Self {
    self + other
  };
}

impl Add for u32 {}

impl Add for Vec2 {
  fn add(self, other: Self) -> Self {
    Vec2 {
      x: self.x + other.x,
      y: self.y + other.y,
    }
  }
}

