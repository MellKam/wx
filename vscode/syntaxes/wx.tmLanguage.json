{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "WX",
	"patterns": [
		{ "include": "#comments" },
		{ "include": "#keywords" },
		{ "include": "#types" },
		{ "include": "#pointers" },
		{ "include": "#numbers" },
		{ "include": "#strings" },
		{ "include": "#chars" },
		{ "include": "#functions" },
		{ "include": "#identifiers" }
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"name": "comment.line.double-slash.wx",
					"match": "//.*$"
				}
			]
		},
		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.wx",
					"match": "\\b(fn|local|mut|if|else|loop|break|continue|return|export|import|global|enum|unreachable|as|impl|self|struct|pub|memory|const|module|trait|for|Self|type|typeset)\\b"
				},
				{
					"name": "constant.language.wx",
					"match": "\\b(true|false)\\b"
				}
			]
		},
		"types": {
			"patterns": [
				{
					"name": "storage.type.wx",
					"match": "\\b(i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|bool|char|never|unit|string)\\b"
				}
			]
		},
		"pointers": {
			"patterns": [
				{
					"name": "keyword.operator.pointer.wx",
					"match": "\\*(?:mut\\b)?"
				}
			]
		},
		"numbers": {
			"patterns": [
				{
					"name": "constant.numeric.float.wx",
					"match": "\\b\\d+\\.\\d+\\b"
				},
				{
					"name": "constant.numeric.binary.wx",
					"match": "\\b0b[01][01_]*\\b"
				},
				{
					"name": "constant.numeric.hex.wx",
					"match": "\\b0x[0-9a-fA-F][0-9a-fA-F_]*\\b"
				},
				{
					"name": "constant.numeric.integer.wx",
					"match": "\\b\\d[\\d_]*\\b"
				}
			]
		},
		"strings": {
			"patterns": [
				{
					"name": "string.quoted.double.wx",
					"begin": "\"",
					"end": "\"",
					"patterns": [
						{
							"name": "constant.character.escape.wx",
							"match": "\\\\."
						}
					]
				}
			]
		},
		"chars": {
			"patterns": [
				{
					"name": "string.quoted.single.wx",
					"match": "'(?:\\\\.|[^'\\\\])*'"
				}
			]
		},
		"functions": {
			"patterns": [
				{
					"name": "entity.name.function.wx",
					"match": "\\b([a-zA-Z_]\\w*)\\s*(?=\\()"
				}
			]
		},
		"identifiers": {
			"patterns": [
				{
					"name": "variable.other.wx",
					"match": "\\b[a-zA-Z_]\\w*\\b"
				}
			]
		}
	},
	"scopeName": "source.wx"
}
