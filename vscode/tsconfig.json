{
	"compilerOptions": {
		"module": "nodenext",
		"target": "esnext",
		"outDir": "out",
		"lib": ["ES2022"],
		"types": ["node"],
		"sourceMap": true,
		"rootDir": "src",
		"strict": true,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true,
		"noUnusedParameters": true,
		"skipLibCheck": true
	}
}
