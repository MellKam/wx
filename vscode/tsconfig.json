{
	"compilerOptions": {
		// `tsdown`/rolldown does the real emit and module resolution now —
		// `tsc` here only typechecks (`--noEmit`), so we use the resolution
		// mode meant for that split: unlike `nodenext`, `bundler` doesn't
		// require a package's `exports` map to have an explicit `types`
		// condition, so it correctly falls back to `ansi-sequence-parser`'s
		// top-level `types` field without needing a `paths` override.
		"module": "preserve",
		"moduleResolution": "bundler",
		"target": "esnext",
		"noEmit": true,
		"lib": ["ES2022"],
		"types": ["node"],
		"rootDir": "src",
		"strict": true,
		"noImplicitReturns": true,
		"noFallthroughCasesInSwitch": true,
		"noUnusedParameters": true,
		"skipLibCheck": true
	},
	"include": ["src"]
}
