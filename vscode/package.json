{
	"name": "wx-vscode",
	"displayName": "WX Language Server",
	"description": "WX language support: syntax highlighting, LSP diagnostics, completions, and formatting",
	"version": "0.0.1",
	"engines": {
		"vscode": "^1.105.0"
	},
	"categories": [
		"Programming Languages"
	],
	"activationEvents": [],
	"main": "./out/extension.js",
	"publisher": "mellkam",
	"repository": {
		"type": "git",
		"url": "https://github.com/MellKam/wx.git"
	},
	"contributes": {
		"commands": [
			{
				"command": "wx-vscode.restartServer",
				"title": "WX: Restart Language Server"
			}
		],
		"languages": [
			{
				"id": "wx",
				"aliases": [
					"WX",
					"wx"
				],
				"extensions": [
					".wx"
				],
				"configuration": "./language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "wx",
				"scopeName": "source.wx",
				"path": "./syntaxes/wx.tmLanguage.json"
			}
		],
		"configurationDefaults": {
			"[wx]": {
				"editor.formatOnSave": true
			}
		},
		"configuration": {
			"type": "object",
			"title": "WX Language Configuration",
			"properties": {
				"wx.formatter.indentSize": {
					"type": "number",
					"default": 2,
					"description": "Number of spaces for indentation",
					"minimum": 1,
					"maximum": 8
				},
				"wx.formatter.maxWidth": {
					"type": "number",
					"default": 80,
					"description": "Maximum line width for formatting",
					"minimum": 40,
					"maximum": 200
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run build",
		"build": "tsc -p ./",
		"watch": "tsc -watch -p ./"
	},
	"dependencies": {
		"ansi-sequence-parser": "^1.1.3",
		"vscode-languageclient": "10.0.1"
	},
	"devDependencies": {
		"@types/node": "^26.1.0",
		"@types/vscode": "^1.125.0",
		"typescript": "^6.0.3"
	},
	"packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b"
}
