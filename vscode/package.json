{
	"name": "wx-vscode",
	"displayName": "WX Language Server",
	"description": "WX language support: syntax highlighting, LSP diagnostics, completions, and formatting",
	"version": "0.0.1",
	"engines": {
		"vscode": "^1.105.0"
	},
	"categories": [
		"Programming Languages"
	],
	"activationEvents": [],
	"main": "./out/extension.js",
	"publisher": "melkam",
	"repository": {
		"type": "git",
		"url": "https://github.com/MellKam/wx.git"
	},
	"contributes": {
		"commands": [
			{
				"command": "wx-vscode.restartServer",
				"title": "WX: Restart Language Server"
			}
		],
		"languages": [
			{
				"id": "wx",
				"aliases": [
					"WX",
					"wx"
				],
				"extensions": [
					".wx"
				],
				"configuration": "./language-configuration.json"
			}
		],
		"grammars": [
			{
				"language": "wx",
				"scopeName": "source.wx",
				"path": "./syntaxes/wx.tmLanguage.json"
			}
		],
		"configuration": {
			"type": "object",
			"title": "WX Language Configuration",
			"properties": {
				"wx.formatOnSave": {
					"type": "boolean",
					"default": true,
					"description": "Automatically format WX files on save"
				},
				"wx.formatter.indentSize": {
					"type": "number",
					"default": 2,
					"description": "Number of spaces for indentation",
					"minimum": 1,
					"maximum": 8
				},
				"wx.formatter.maxWidth": {
					"type": "number",
					"default": 100,
					"description": "Maximum line width for formatting",
					"minimum": 40,
					"maximum": 200
				}
			}
		}
	},
	"scripts": {
		"vscode:prepublish": "npm run build",
		"build": "tsc -p ./",
		"watch": "tsc -watch -p ./"
	},
	"dependencies": {
		"vscode-languageclient": "9.0.1"
	},
	"devDependencies": {
		"@types/vscode": "^1.110.0",
		"@types/node": "^24.0.3",
		"typescript": "5.8.3"
	}
}
