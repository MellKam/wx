use std::*;

memory heap: Memory where { Size = u32 } { min_pages: 1 };

trait Allocator {
    type M: Memory;

    fn alloc(self: Self::M::*mut Self, layout: Layout<Self::M>) -> *mut u8;
}

struct BumpAllocator<M: Memory> {
    bump: M::Size,
}

module xor {
    pub fn test() {}
}

impl<M: Memory> BumpAllocator<M> {
    fn new() {}
}

impl Allocator for BumpAllocator<heap> {
    type M = heap;

    fn alloc(self: Self::M::*mut Self, layout: Layout<Self::M>) -> *mut u8 {
        local align_mask = layout.align - 1;
        local start = (self.*.bump + align_mask) & ^align_mask;
        
        // 2. Calculate the end address of this allocation
        local end = start + layout.size;
        
        // 3. Check if we have exceeded the current WebAssembly memory size.
        // `heap.size()` returns pages, so we multiply by your PAGE_SIZE constant (65536).
        local current_bytes = heap.size() * PAGE_SIZE;
        
        if end > current_bytes {
            local bytes_needed = end - current_bytes;
            local pages_needed = (bytes_needed + PAGE_SIZE - 1) / PAGE_SIZE;
            
            // Grow the WebAssembly memory
            // (Note: In a production language, you should check if `grow` 
            // returns -1 to handle Out-Of-Memory errors).
            _ = heap.grow(pages_needed);
        };
        
        // 4. Advance the bump pointer to the end of this allocation
        self.*.bump = end;
        
        // 5. Cast and return the starting address
        start as _
    }
}

fn main() {
    local bump: *mut BumpAllocator<heap> = unreachable;
    local ptr = bump.alloc(Layout::{ size: 4, align: 1 });
}

// ── bump allocator ────────────────────────────────────────────────────────────
global mut bump: heap::*u8 = heap::DATA_END;

fn alloc_bytes(size: u32, align: u32) -> heap::*mut u8 {
    local ptr = (bump as u32 + align - 1) / align * align;
    local new_end = ptr + size;
    local cur_end = heap.size() * PAGE_SIZE;
    if new_end > cur_end {
        local needed = (new_end - cur_end + PAGE_SIZE - 1) / PAGE_SIZE;
        _ = heap.grow(needed);
    }
    bump = new_end as heap::*u8;
    ptr as heap::*mut u8
}

fn alloc_array<T>(count: u32) -> heap::*mut T {
    alloc_bytes(size_of::<T, heap>() * count, align_of::<T, heap>()) as _
}

pub fn reset() {
    bump = heap::DATA_END;
}

// ── Vec<T> ────────────────────────────────────────────────────────────────────
struct Vec<T> {
    buf: heap::*mut T,
    len: u32,
    cap: u32,
}

impl<T> Vec<T> {
    #[inline]
    pub fn new() -> Vec<T> {
        Vec::{ buf: ptr::null_mut(), len: 0, cap: 0 }
    }

    // Appends a value; grows the buffer if needed (doubles capacity each time).
    pub fn push(self: heap::*mut Self, value: T) {
        if self.*.len == self.*.cap {
            local new_cap = if self.*.cap == 0 { 4 } else { self.*.cap * 2 };
            local new_buf = alloc_array::<T>(new_cap);
            if self.*.cap != 0 {
                local bytes = self.*.len * size_of::<T, heap>();
                memory_copy(
                    new_buf as heap::*mut u8,
                    self.*.buf as heap::*u8,
                    bytes,
                );
            };
            self.*.buf = new_buf;
            self.*.cap = new_cap;
        };
        ptr::add_mut(self.*.buf, self.*.len).* = value;
        self.*.len += 1;
    }

    // Removes and returns the last element. Caller must ensure len > 0.
    pub fn pop(self: heap::*mut Self) -> T {
        self.*.len -= 1;
        ptr::add(self.*.buf, self.*.len).*
    }

    // Removes the element at index, shifting everything after it left. O(n).
    pub fn remove(self: heap::*mut Self, index: u32) -> T {
        local val = ptr::add(self.*.buf, index).*;
        local mut i: u32 = index;
        loop {
            if i + 1 == self.*.len { break; };
            ptr::add_mut(self.*.buf, i).* = ptr::add(self.*.buf, i + 1).*;
            i += 1;
        };
        self.*.len -= 1;
        val
    }

    // Removes the element at index by swapping it with the last. O(1), no order.
    pub fn swap_remove(self: heap::*mut Self, index: u32) -> T {
        local val = ptr::add(self.*.buf, index).*;
        self.*.len -= 1;
        if index != self.*.len {
            ptr::add_mut(self.*.buf, index).*
                = ptr::add(self.*.buf, self.*.len).*;
        };
        val
    }

    pub fn get(self: heap::*Self, index: u32) -> T {
        ptr::add(self.*.buf, index).*
    }

    pub fn set(self: heap::*mut Self, index: u32, value: T) {
        ptr::add_mut(self.*.buf, index).* = value;
    }

    pub fn swap(self: heap::*mut Self, a: u32, b: u32) {
        local tmp = ptr::add(self.*.buf, a).*;
        ptr::add_mut(self.*.buf, a).* = ptr::add(self.*.buf, b).*;
        ptr::add_mut(self.*.buf, b).* = tmp;
    }

    pub fn first(self: heap::*Self) -> T {
        self.*.buf.*
    }

    pub fn last(self: heap::*Self) -> T {
        ptr::add(self.*.buf, self.*.len - 1).*
    }

    pub fn clear(self: heap::*mut Self) {
        self.*.len = 0;
    }

    #[inline]
    pub fn len(self: heap::*Self) -> u32 {
        self.*.len
        // hello world
    }

    #[inline]
    pub fn cap(self: heap::*Self) -> u32 {
        self.*.cap
    }

    #[inline]
    pub fn is_empty(self: heap::*Self) -> bool {
        self.*.len == 0
    }
}

// ── demo ─────────────────────────────────────────────────────────────────────
pub fn demo() -> i32 {
    local vec = alloc_array::<Vec<i32>>(1);
    vec.* = Vec::new();
    
    // &[1, 2, 3]
    // &mut [1, 2, 3]
    // [1, 2, 3].&mut
    // Point::{ x: 1, y: 1, z: 1 }.&mut
    // object.*.field.&mut
    vec.push(10);
    vec.push(20);
    vec.push(30);
    vec.push(40);
    vec.push(50);
    
    _ = vec.pop();
    // remove 50
    vec.set(1, 99);
    // [10, 99, 30, 40]
    vec.swap(0, 3);
    // [40, 99, 30, 10]
    _ = vec.swap_remove(1);
    // [40, 10, 30]
    local mut sum: i32 = 0;
    local mut i: u32 = 0;
    
    loop {
        if i == vec.len() { break sum }
        sum += vec.get(i);
        i += 1;
    }
}

export {
    heap as "memory",
    reset,
    demo,
}
