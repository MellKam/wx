fn plus(a: i32, b: i32) -> i32 {
  a + b
}

impl i32 {
  fn add(a: i32, b: i32) -> i32 {
    a + b
  }
}

trait Mem {
  type Size;

  fn alloc(n: Self::Size) -> *mut u8;
}
