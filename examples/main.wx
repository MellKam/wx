memory heap: Memory<Size = u32>;

trait PointerSize {
  fn size() -> u32;
}

impl PointerSize for i64 {
  fn size() -> u32 {
    4
  }
}

struct Layout<M: Memory> {
  size: M::Size,
  align: M::Size,
}

impl <M: Memory> Layout<M> {
  pub fn of<T>() -> Layout<M> {
    Layout::{ size: @size_of::<T, _>(), align: @align_of::<T, _>() }
  }
}

fn main() {
  _ = test::<i32, i32>(5);
}
